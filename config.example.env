# 3moj00 Website Configuration Example
# Copy this file to config.env and modify as needed

# Server Configuration
PORT=8000
HOST=localhost

# Website Configuration
SITE_TITLE=3moj00 - Video Editor Portfolio
SITE_DESCRIPTION=Professional video editing and motion graphics services
SITE_URL=http://localhost:8000

# Developer Panel Configuration
DEV_PANEL_ENABLED=true
DEV_PANEL_SECRET_CODE=15987530

# Data Configuration
DATA_FILE_PATH=./data/data.json
BACKUP_ENABLED=true

# Performance Configuration
CACHE_ENABLED=true
CACHE_DURATION=300000

# Security Configuration
CORS_ENABLED=true
RATE_LIMIT_ENABLED=false

# Development Configuration
DEBUG_MODE=true
LOG_LEVEL=info
